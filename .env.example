# ============================================================
# GRZLY — Environment Variables
# Copy this file to .env.local and fill in all values.
# NEVER commit .env.local to version control.
# ============================================================


# ------------------------------------------------------------
# SUPABASE
# Get these from: Supabase Dashboard → Settings → API
# ------------------------------------------------------------

# Your project URL (safe to expose to browser)
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co

# Anonymous/public key (safe to expose to browser — RLS protects data)
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# Service role key (NEVER expose to browser — bypasses RLS)
# Used only in server-side cron jobs and lore generation
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...


# ------------------------------------------------------------
# POLYGON.IO — Price data
# Get from: https://polygon.io/dashboard/api-keys
# Plan: Starter ($29/mo) — required for EOD closing prices
# ------------------------------------------------------------

POLYGON_API_KEY=your_polygon_api_key_here


# ------------------------------------------------------------
# FINNHUB — News and market data
# Get from: https://finnhub.io/dashboard → API Key
# Plan: Free tier (60 calls/min) is sufficient for MVP
# ------------------------------------------------------------

FINNHUB_API_KEY=your_finnhub_api_key_here


# ------------------------------------------------------------
# OPENAI — Lore narrative generation
# Get from: https://platform.openai.com/api-keys
# Model: gpt-4o recommended; gpt-4o-mini acceptable for cost savings
# Estimated cost: ~$15-25/month at MVP scale
# ------------------------------------------------------------

OPENAI_API_KEY=sk-...

# Which model to use for lore generation
# Options: gpt-4o | gpt-4o-mini | claude-3-5-sonnet-20241022
OPENAI_LORE_MODEL=gpt-4o

# Version tag for prompt tracking — increment when you change prompts
# This is logged to lore_events.prompt_version for every generation
LORE_PROMPT_VERSION=v1.0


# ------------------------------------------------------------
# REDDIT API — Community signal scraper
# Register your app at: https://www.reddit.com/prefs/apps
# App type: "script" (for server-to-server use)
# ------------------------------------------------------------

REDDIT_CLIENT_ID=your_reddit_client_id
REDDIT_CLIENT_SECRET=your_reddit_client_secret

# Must include your Reddit username and app name
# Example: "GRZLY:v1.0 (by u/your_reddit_username)"
REDDIT_USER_AGENT=GRZLY:v1.0 (by u/your_username)


# ------------------------------------------------------------
# APP CONFIGURATION
# ------------------------------------------------------------

# Your public app URL (no trailing slash)
# Dev: http://localhost:3000
# Prod: https://grzly.com (or your Vercel URL)
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Set to "true" to enable waitlist mode (blocks sign-ups, shows waitlist form)
# Set to "false" to open registration
NEXT_PUBLIC_WAITLIST_MODE=true

# Secret key for signing cron job requests (generate a random string)
# Passed as Bearer token in Authorization header when Vercel calls cron routes
CRON_SECRET=generate_a_random_secret_here
